if(NOT CMAKE_INSTALL_LOCAL_ONLY)
  file(WRITE "D:/Workspace/VS-Code/STM32/SS_GSMD_rev2.2_09.07.2023/build/debug/build/${CMAKE_INSTALL_MANIFEST}"
     "${CMAKE_INSTALL_MANIFEST_CONTENT}")
